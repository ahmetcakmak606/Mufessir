{
  "name": "Mufessir",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "npm run test:frontend && npm run test:backend",
    "test:backend": "npm --workspace apps/backend run test",
    "test:frontend": "npm --workspace apps/frontend run test",
    "test:coverage": "npm run test:coverage:frontend && npm run test:coverage:backend",
    "test:coverage:frontend": "npm --workspace apps/frontend run test:coverage",
    "test:coverage:backend": "npm --workspace apps/backend run test:coverage",
    "test:e2e:frontend": "npm --workspace apps/frontend run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:up": "docker compose up -d",
    "db:migrate": "cd packages/database && npx prisma generate && npx prisma db push --skip-generate",
    "db:seed": "npm --workspace apps/backend run seed",
    "db:derive": "npm --workspace apps/backend run derive-scholar-metadata",
    "db:export:scholar-starter": "npm --workspace apps/backend run export-scholar-enrichment-starter",
    "db:enrich:scholars": "npm --workspace apps/backend run import-scholar-enrichment",
    "quality:scholars": "npm --workspace apps/backend run quality:scholars",
    "setup:dev": "npm run db:up && npm run db:migrate && npm run db:seed"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.4.4",
    "typescript": "5.8.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.7.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "prisma": "^5.22.0"
  }
}
