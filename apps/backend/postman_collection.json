{
  "info": {
    "name": "Mufessir Backend API - Smoke Suite",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "mufessir-backend-smoke-suite"
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('Response is not 5xx', function () {",
          "  pm.expect(pm.response.code).to.be.below(500);",
          "});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "00 - Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Health payload has status=ok', function () {",
                  "  pm.expect(json.status).to.eql('ok');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "10 - Auth",
      "item": [
        {
          "name": "POST /auth/register (idempotent)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.collectionVariables.get('userEmail')) {",
                  "  const suffix = Date.now();",
                  "  pm.collectionVariables.set('userEmail', `postman_${suffix}@example.com`);",
                  "}",
                  "if (!pm.collectionVariables.get('userPassword')) {",
                  "  pm.collectionVariables.set('userPassword', 'pass1234');",
                  "}",
                  "if (!pm.collectionVariables.get('userName')) {",
                  "  pm.collectionVariables.set('userName', 'Postman User');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 or 409', function () {",
                  "  pm.expect([201, 409]).to.include(pm.response.code);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json && json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\",\n  \"name\": \"{{userName}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "POST /auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Token exists', function () {",
                  "  pm.expect(json.token).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.collectionVariables.set('token', json.token);",
                  "pm.test('x-auth-latency-ms header exists and is numeric', function () {",
                  "  const latency = pm.response.headers.get('x-auth-latency-ms');",
                  "  pm.expect(latency).to.not.equal(undefined);",
                  "  pm.expect(Number.isNaN(Number(latency))).to.equal(false);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "POST /auth/sso/google (missing token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/sso/google",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "sso", "google"]
            }
          }
        },
        {
          "name": "POST /auth/sso/apple (missing token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/sso/apple",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "sso", "apple"]
            }
          }
        },
        {
          "name": "GET /auth/me",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Email matches logged in user', function () {",
                  "  pm.expect(json.email).to.eql(pm.collectionVariables.get('userEmail'));",
                  "});",
                  "pm.test('Daily quota is present', function () {",
                  "  pm.expect(json.dailyQuota).to.be.a('number');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            }
          }
        },
        {
          "name": "POST /auth/password/reset/request",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('ok=true', function () {",
                  "  pm.expect(json.ok).to.eql(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/password/reset/request",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "password", "reset", "request"]
            }
          }
        },
        {
          "name": "POST /auth/password/reset/confirm (optional/manual)",
          "description": "Set {{resetCode}} from your dev email output first. If no code is provided this should return 400, which still proves endpoint responsiveness.",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 400', function () {",
                  "  pm.expect([200, 400]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"code\": \"{{resetCode}}\",\n  \"newPassword\": \"{{userPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/password/reset/confirm",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "password", "reset", "confirm"]
            }
          }
        }
      ]
    },
    {
      "name": "20 - Filters",
      "item": [
        {
          "name": "GET /filters",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('scholars array exists', function () {",
                  "  pm.expect(json.scholars).to.be.an('array');",
                  "});",
                  "pm.test('filterOptions has normalized dimensions', function () {",
                  "  pm.expect(json.filterOptions).to.be.an('object');",
                  "  pm.expect(json.filterOptions.centuries).to.be.an('array');",
                  "  pm.expect(json.filterOptions.periods).to.be.an('array');",
                  "  pm.expect(json.filterOptions.madhabs).to.be.an('array');",
                  "  pm.expect(json.filterOptions.environments).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/filters",
              "host": ["{{baseUrl}}"],
              "path": ["filters"]
            }
          }
        }
      ]
    },
    {
      "name": "30 - Verses",
      "item": [
        {
          "name": "GET /verses?surahNumber&verseNumber",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Verse object has id', function () {",
                  "  pm.expect(json.id).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.collectionVariables.set('verseId', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/verses?surahNumber={{surahNumber}}&verseNumber={{verseNumber}}",
              "host": ["{{baseUrl}}"],
              "path": ["verses"],
              "query": [
                {
                  "key": "surahNumber",
                  "value": "{{surahNumber}}"
                },
                {
                  "key": "verseNumber",
                  "value": "{{verseNumber}}"
                }
              ]
            }
          }
        },
        {
          "name": "GET /verses (list)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('items array exists', function () {",
                  "  pm.expect(json.items).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/verses?take=5",
              "host": ["{{baseUrl}}"],
              "path": ["verses"],
              "query": [
                {
                  "key": "take",
                  "value": "5"
                }
              ]
            }
          }
        },
        {
          "name": "GET /verses?q=... (search)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Search response includes items array', function () {",
                  "  pm.expect(json.items).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/verses?q=Allah&take=3",
              "host": ["{{baseUrl}}"],
              "path": ["verses"],
              "query": [
                {
                  "key": "q",
                  "value": "Allah"
                },
                {
                  "key": "take",
                  "value": "3"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "40 - Tafseer",
      "item": [
        {
          "name": "POST /tafseer (unauthorized)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 401', function () {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"verseId\": \"{{verseId}}\",\n  \"filters\": {\n    \"tone\": 7,\n    \"intellectLevel\": 7,\n    \"language\": \"English\"\n  },\n  \"stream\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tafseer",
              "host": ["{{baseUrl}}"],
              "path": ["tafseer"]
            }
          }
        },
        {
          "name": "POST /tafseer (non-streaming)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Response includes AI output', function () {",
                  "  pm.expect(json.aiResponse).to.be.a('string');",
                  "});",
                  "pm.test('Response includes confidence + citations', function () {",
                  "  pm.expect(json).to.have.property('confidence');",
                  "  pm.expect(json.citations).to.be.an('array');",
                  "});",
                  "pm.test('Response includes source excerpts', function () {",
                  "  pm.expect(json.sourceExcerpts).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"verseId\": \"{{verseId}}\",\n  \"filters\": {\n    \"tone\": 7,\n    \"intellectLevel\": 7,\n    \"language\": \"English\"\n  },\n  \"stream\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tafseer",
              "host": ["{{baseUrl}}"],
              "path": ["tafseer"]
            }
          }
        },
        {
          "name": "POST /tafseer (streaming SSE)",
          "description": "Postman does not render chunks in real-time, but full SSE payload can still be validated after completion.",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const text = pm.response.text();",
                  "pm.test('SSE envelope is present', function () {",
                  "  pm.expect(text).to.include('data:');",
                  "  pm.expect(text).to.include('\"type\":\"complete\"');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Accept",
                "value": "text/event-stream"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"verseId\": \"{{verseId}}\",\n  \"filters\": {\n    \"tone\": 7,\n    \"intellectLevel\": 7,\n    \"language\": \"English\"\n  },\n  \"stream\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tafseer",
              "host": ["{{baseUrl}}"],
              "path": ["tafseer"]
            }
          },
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000"
    },
    {
      "key": "userEmail",
      "value": ""
    },
    {
      "key": "userPassword",
      "value": "pass1234"
    },
    {
      "key": "userName",
      "value": "Postman User"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "surahNumber",
      "value": "1"
    },
    {
      "key": "verseNumber",
      "value": "1"
    },
    {
      "key": "verseId",
      "value": ""
    },
    {
      "key": "resetCode",
      "value": ""
    }
  ]
}
