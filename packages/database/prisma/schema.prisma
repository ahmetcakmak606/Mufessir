generator client {
  provider        = "prisma-client-js"
  binaryTargets  = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DB_URL")
}

enum ScholarPeriod {
  FOUNDATION
  CLASSICAL_EARLY
  CLASSICAL_MATURE
  POST_CLASSICAL
  MODERN
  CONTEMPORARY
}

enum TraditionAcceptance {
  SUNNI_MAINSTREAM
  MUTAZILI
  SHII_IMAMI
  SHII_ZAYDI
  SUFI_ISHARI
  IBADI
  SALAFI
  CROSS_TRADITION
}

enum SourceAccessibility {
  FULL_DIGITAL
  PARTIAL_DIGITAL
  MANUSCRIPT_ONLY
  LOST
}

model Surah {
  id              Int     @id
  surahNumber     Int     @unique @map("surah_number")
  nameAr          String? @map("surah_name_ar")
  nameTr          String? @map("surah_name_tr")
  nameEn          String? @map("surah_name_en")
  totalAyahs      Int     @map("total_ayahs")
  revelationType  String? @map("revelation_type")
  revelationOrder Int?    @map("revelation_order")
  verses          Verse[]

  @@map("surahs")
}

model Verse {
  id              String   @id
  verseNumber     Int      @map("ayah_number")
  surahNumber     Int      @map("surah_id")
  arabicText      String   @map("ayah_text_ar")
  transliteration String?
  translation     String?  @map("ayah_text_tr")
  surah           Surah    @relation(fields: [surahNumber], references: [id])
  tafsirs         Tafsir[]

  @@unique([surahNumber, verseNumber])
  @@index([surahNumber])
  @@map("ayahs")
}

model Mufassir {
  id                  Int      @id @map("mufassir_id")
  nameEn              String?  @map("mufassir_en")
  nameTr              String?  @map("mufassir_tr")
  nameAr              String?  @map("mufassir_ar")
  nameLong            String?  @map("mufassir_name_long")
  bookTafsir          String?  @map("mufassirs_tafsir")
  bookTafsirAr        String?  @map("mufassirs_tafsir_ar")
  bookId              Int?     @map("book_id")
  deathHijri          Int?     @map("death_hijri")
  deathMiladi         Int?     @map("death_miladi")
  century             Int?
  period              String?
  periodCode          String?
  madhab              String?
  environment         String?
  originCountry       String?  @map("origin_country")
  reputationScore     Float?   @map("reputation_score")
  explanation         String?  @db.Text
  detailInformation   String?  @db.Text
  tafsirType1         String?  @map("tafsir_type1")
  tafsirType2         String?  @map("tafsir_type2")
  sourceAccessibility String?  @map("source_accessibility")
  scholarlyInfluence  Float?
  methodologicalRigor Float?
  corpusBreadth       Float?
  traditionAcceptance String[] @default([])
  tafsirs             Tafsir[]

  @@map("mufassirs")
}

model Tafsir {
  id            String   @id @default(cuid())
  verseId       String   @map("verse_id")
  mufassirId    Int      @map("mufassir_id")
  tafsirText    String   @map("commentary") @db.Text
  tafsirType    String?  @map("tafsir_type")
  keywords      String[] @default([])
  methodTags    String[] @default(["MIXED"])
  languageLevel Float?   @map("language_level")
  emotionalRatio Float?  @map("emotional_ratio")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt
  verse         Verse    @relation(fields: [verseId], references: [id])
  mufassir      Mufassir @relation(fields: [mufassirId], references: [id])

  @@index([verseId])
  @@index([mufassirId])
  @@map("all_tafsirs")
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  passwordHash   String
  name           String?
  openaiApiKey   String?
  dailyQuota     Int             @default(10)
  quotaResetAt   DateTime        @default(now())
  emailVerified  Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  searches       Search[]
  favorites      Favorite[]
  passwordResets PasswordReset[]
}

model Search {
  id        String         @id @default(cuid())
  userId    String         @map("user_id")
  verseId   String         @map("verse_id")
  query     Json
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id])
  results   SearchResult[]

  @@map("searches")
}

model SearchResult {
  id              String   @id @default(cuid())
  searchId        String   @map("search_id")
  tafsirId        String   @map("tafsir_id")
  aiResponse      String   @db.Text
  citations       Json?
  confidenceScore Float?
  similarityScore Float?
  createdAt       DateTime @default(now())
  search          Search   @relation(fields: [searchId], references: [id])

  @@map("search_results")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  verseId   String   @map("verse_id")
  note      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@map("favorites")
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  codeHash  String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model AcademicSnapshot {
  id               String   @id @default(cuid())
  snapshotId       String   @unique
  verseId          String
  queryText        String
  corpusVersion    String
  embeddingModel   String
  llmModel         String
  promptHash       String
  aiResponse       String   @db.Text
  arabicTafsir     String?  @db.Text
  turkishTafsir    String?  @db.Text
  retrievedSources Json?
  confidence       Float?
  provenance       String?
  citations        Json?
  generatedAt      DateTime @default(now())
  citationKey      String
  searchId         String?
}
