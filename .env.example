## Backend (loaded from repo root by apps/backend)

# Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mufessir
SHADOW_DB_URL=postgresql://postgres:postgres@localhost:5432/mufessir_shadow

# Auth & quotas
JWT_SECRET=change_me_in_prod
FREE_DAILY_QUOTA=10
# Google SSO backend audience (Google OAuth Client ID)
# GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# Optionally allow multiple IDs (comma separated)
# GOOGLE_CLIENT_IDS=client-id-1.apps.googleusercontent.com,client-id-2.apps.googleusercontent.com
# Apple SSO backend audience (Apple Services ID)
# APPLE_CLIENT_ID=com.example.web
# Optionally allow multiple IDs (comma separated)
# APPLE_CLIENT_IDS=com.example.web,com.example.web.staging

# App URLs
APP_URL=http://localhost:3000

# OpenAI (optional in development)
# Set AI_MODE=off or OPENAI_DISABLED=1 to force fallback behavior
# AI_MODE=on
# OPENAI_DISABLED=0
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TEMPERATURE=0.7
# OPENAI_MAX_TOKENS=800

# Similarity mode
# Use 'sample' to skip embeddings and use sample similarity in dev
SIMILARITY_MODE=sample

# SMTP (optional; if omitted, emails are logged to console)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=username
# SMTP_PASS=password
# EMAIL_FROM=no-reply@mufessir.local

## Frontend (can also be set in apps/frontend/.env.local)
# NEXT_PUBLIC_API_URL=http://localhost:4000
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# NEXT_PUBLIC_APPLE_CLIENT_ID=com.example.web
# NEXT_PUBLIC_APPLE_REDIRECT_URI=http://localhost:3000
